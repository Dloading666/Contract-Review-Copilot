# ZhipuAI GLM-5 (Main LLM)
OPENAI_API_KEY=your_zhipuai_api_key_here
OPENAI_BASE_URL=https://coding.dashscope.aliyuncs.com/v1
OPENAI_MODEL=glm-5

# Optional cloud model names (reuse the same OPENAI_API_KEY + OPENAI_BASE_URL)
MINIMAX_MODEL=MiniMax-M2.5
QWEN_MODEL=qwen-plus
KIMI_MODEL=kimi-k2.5

# Local Gemma4 fallback via Ollama
PRIMARY_LLM_MODEL_KEY=gemma4
GEMMA4_BASE_URL=http://localhost:11434/v1
GEMMA4_MODEL=contract-gemma4:latest

# Redis cache
REDIS_ENABLED=true
REDIS_URL=redis://localhost:6379/0
REDIS_SESSION_TTL_SECONDS=7200
REDIS_SEARCH_TTL_SECONDS=1800
REDIS_LLM_TTL_SECONDS=3600

# ZhipuAI text-embedding-v4 (Embeddings)
EMBEDDING_API_KEY=your_embedding_api_key_here
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v4

# PostgreSQL + pgvector
DATABASE_URL=postgresql://contract_user:contract_pass@localhost:5432/contract_review
AUTO_SEED_LEGAL_KNOWLEDGE=1

# SMTP (optional - for sending verification emails)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=

# JWT secret
JWT_SECRET=your_jwt_secret_here

# SiliconFlow models
OPENAI_API_KEY=your_siliconflow_api_key_here
OPENAI_BASE_URL=https://api.siliconflow.cn/v1
REVIEW_MODEL=Qwen/Qwen3.5-4B
OCR_MODEL=PaddlePaddle/PaddleOCR-VL-1.5

# Redis cache / rate limit
REDIS_ENABLED=true
REDIS_URL=redis://localhost:6379/0
REDIS_SESSION_TTL_SECONDS=7200
REDIS_SEARCH_TTL_SECONDS=1800
REDIS_LLM_TTL_SECONDS=3600
REDIS_AUTH_CODE_TTL_SECONDS=300

# PostgreSQL + pgvector
DATABASE_URL=postgresql://contract_user:contract_pass@localhost:5432/contract_review
AUTO_SEED_LEGAL_KNOWLEDGE=1

# Embeddings
EMBEDDING_API_KEY=your_embedding_api_key_here
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v4

# JWT / CORS
JWT_SECRET=your_jwt_secret_here
JWT_SECRET_FILE=
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
ALLOW_DEV_CODE_RESPONSE=false

# SMTP (optional, for auxiliary email registration / login)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=

# Commercialization
FREE_REVIEW_COUNT=2
REVIEW_PRICE_FEN=100
REVIEW_QUESTION_QUOTA=15
EXTRA_QUESTION_PRICE_FEN=8
RECHARGE_MIN_AMOUNT_FEN=100
RECHARGE_QUICK_AMOUNTS=100,990,1990

# Aliyun SMS Verify
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=
ALIYUN_SMS_SCHEME_NAME=
ALIYUN_SMS_REGION_ID=cn-hangzhou
ALIYUN_SMS_ENDPOINT=https://dypnsapi.aliyuncs.com

# WeChat Pay Native
WECHAT_PAY_APPID=
WECHAT_PAY_MCHID=
WECHAT_PAY_SERIAL_NO=
WECHAT_PAY_PRIVATE_KEY_PATH=
WECHAT_PAY_PRIVATE_KEY_PEM=
WECHAT_PAY_PLATFORM_SERIAL_NO=
WECHAT_PAY_PLATFORM_CERT_PATH=
WECHAT_PAY_PLATFORM_CERT_PEM=
WECHAT_PAY_API_V3_KEY=
WECHAT_PAY_NOTIFY_URL=
WECHAT_PAY_API_BASE_URL=https://api.mch.weixin.qq.com

# syntax=docker/dockerfile:1

FROM python:3.11-slim

WORKDIR /app

# Copy application source before install so packaging works in Docker
COPY pyproject.toml .
COPY src/ ./src/

# Use pip's cache mount so transient network issues don't force a full re-download
# on the next build retry.
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install --upgrade pip \
    && pip install -e .

# .env is provided via env_file in docker-compose

EXPOSE 8000

CMD ["python", "-m", "src.startup"]

FROM python:3.11-slim

WORKDIR /app

# Copy application source before install so packaging works in Docker
COPY pyproject.toml .
COPY src/ ./src/

# Keep the install step compatible with environments where BuildKit is unavailable.
RUN pip install --upgrade pip \
    && pip install -e .

# .env is provided via env_file in docker-compose

EXPOSE 8000

CMD ["python", "-m", "src.startup"]

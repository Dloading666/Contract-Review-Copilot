# syntax=docker/dockerfile:1

FROM python:3.11-slim

WORKDIR /app

# Install uv
RUN pip install --upgrade pip && pip install --no-cache-dir uv

# Copy application source before install so editable packaging works in Docker
COPY pyproject.toml .
COPY src/ ./src/
RUN uv pip install --system --no-cache -e .

# .env is provided via env_file in docker-compose

EXPOSE 8000

CMD ["python", "-m", "src.startup"]

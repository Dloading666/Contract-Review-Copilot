# ============================================================
# 合规智审 Copilot — Docker 部署环境变量模板
# 复制此文件为 backend/.env 并填入真实值
# ============================================================

# ---------- 必填项 ----------

# OpenRouter API（主力模型 Gemma 4 / Nemotron VL）
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# SiliconFlow API（备用模型 Qwen3.5-4B / PaddleOCR）
OPENAI_API_KEY=your_siliconflow_api_key_here
OPENAI_BASE_URL=https://api.siliconflow.cn/v1

# JWT 密钥（生产环境请使用随机字符串）
JWT_SECRET=change_me_to_a_random_64_char_hex_string

# 数据库密码
POSTGRES_PASSWORD=change_me_postgres_password

# Redis 密码
REDIS_PASSWORD=change_me_redis_password

# ---------- 模型配置（通常不需要修改） ----------

# 主力审查模型：Gemma 4 26B A4B MoE（速度最快）
PRIMARY_REVIEW_MODEL=deepseek-v4-flash

# 主力 OCR 模型：Nemotron Nano 12B VL
PRIMARY_OCR_MODEL=PaddlePaddle/PaddleOCR-VL-1.5

# 备用审查模型：Gemma 4 31B（质量更优）
FALLBACK_REVIEW_MODEL=

# 备用 OCR 模型：PaddleOCR-VL
FALLBACK_OCR_MODEL=
OCR_FALLBACK_API_KEY=your_siliconflow_api_key_here
OCR_FALLBACK_BASE_URL=https://api.siliconflow.cn/v1

# 第三备用模型：Qwen3.5-4B（SiliconFlow 免费兜底）
TERTIARY_REVIEW_MODEL=Qwen/Qwen3.5-4B

# ---------- Embedding 模型（向量数据库） ----------
EMBEDDING_API_KEY=your_embedding_api_key_here
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v4

# ---------- Redis 配置 ----------
REDIS_ENABLED=true
REDIS_URL=redis://localhost:6379/0
REDIS_SESSION_TTL_SECONDS=7200
REDIS_SEARCH_TTL_SECONDS=1800
REDIS_LLM_TTL_SECONDS=3600

# ---------- PostgreSQL ----------
DATABASE_URL=postgresql://contract_user:contract_pass@localhost:5432/contract_review
AUTO_SEED_LEGAL_KNOWLEDGE=1

# ---------- CORS ----------
CORS_ALLOWED_ORIGINS=https://your-domain.com,http://localhost:3000,http://localhost:5173
ALLOW_DEV_CODE_RESPONSE=false

# ---------- SMTP（可选，发送验证码邮件） ----------
# SMTP_HOST=smtp.qq.com
# SMTP_PORT=587
# SMTP_USER=your_email@example.com
# SMTP_PASSWORD=your_email_password
# FROM_EMAIL=noreply@example.com

# ---------- GitHub OAuth（可选） ----------
# GITHUB_CLIENT_ID=your_github_client_id
# GITHUB_CLIENT_SECRET=your_github_client_secret
# GITHUB_OAUTH_REDIRECT_URI=https://your-domain.com/api/auth/github/callback

# ---------- 调试开关（生产环境务必设为 0） ----------
SKIP_LLM_EXTRACTION=0
SKIP_LLM_ROUTING=0
SKIP_LLM_REVIEW=0
SKIP_LLM_REPORT=0

# ---------- Docker 部署专用变量 ----------
LOG_LEVEL=INFO
FRONTEND_PORT=3001
BACKEND_PORT=8000
POSTGRES_PORT=5432
REDIS_PORT=6379
FRONTEND_HOST=127.0.0.1
BACKEND_HOST=127.0.0.1
POSTGRES_HOST=127.0.0.1
REDIS_HOST=127.0.0.1
REDIS_MAXMEMORY=256mb
